---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const doctors = [
  ['Dt. Ayşe Yılmaz','Estetik Diş Hekimliği','Gülüş tasarımı, veneer ve zirkonyum restorasyonlar.'],
  ['Dr. Emre Kaya','Ağız, Diş ve Çene Cerrahisi','İmplant cerrahisi ve ileri cerrahi uygulamalar.'],
  ['Dt. Selin Demir','Ortodonti','Şeffaf plak ve sabit ortodontik tedaviler.'],
];
---
<BaseLayout title="Hekimlerimiz | MOVA Oral Intelligence" description="MOVA Oral Intelligence’un multidisipliner diş hekimi ekibiyle tanışın.">
  <section class="section">
    <div class="container">
      <span class="eyebrow">Hekimlerimiz</span>
      <h1 style="font-size:clamp(2.5rem,6vw,5rem)">Bilimsel yaklaşım, sakin iletişim.</h1>
      <div class="grid grid-3" style="margin-top:38px">
        {doctors.map(([name,branch,bio],i)=>(
          <article class="card">
            <div style={`height:280px;border-radius:22px;margin-bottom:22px;background:linear-gradient(145deg,${i%2?'#dcebe6':'#eee4d5'},#fff);display:grid;place-items:center;font-size:4rem;font-weight:900;color:var(--accent)`}>{name.charAt(4)}</div>
            <span class="pill">{branch}</span><h3 style="margin-top:15px">{name}</h3><p class="muted">{bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
<div class="container" style="padding:18px 0 42px"><small>ترجمه کامل این صفحه در مرحله بعد تکمیل می‌شود.</small></div>
</BaseLayout>
