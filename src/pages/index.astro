---
import BaseLayout from '../layouts/BaseLayout.astro';
import Mova3DHero from '../components/Mova3DHero.astro';
const services = [
  ['Implant Dentistry','Permanent, aesthetic and functional solutions for missing teeth.','I'],
  ['Smile Design','A naturally balanced smile, digitally planned around your face.','S'],
  ['Ceramic Restorations','Strong, light-transmitting restorations with a natural finish.','C'],
  ['Orthodontics','Clear aligners and modern orthodontic treatment options.','O'],
  ['Endodontics','Precision root canal care focused on preserving the natural tooth.','E'],
  ['Pediatric Dentistry','Gentle, preventive care designed to build lifelong confidence.','P'],
];
---
<BaseLayout immersive title="MOVA Oral Intelligence | Future Dental Clinic Concept" description="MOVA Oral Intelligence is a future dental clinic concept combining AI-assisted digital dentistry, natural aesthetics, emotional care and separate adult and pediatric experiences.">
  <Mova3DHero locale="en" />

  <section class="section">
    <div class="container">
      <span class="eyebrow">Treatments</span>
      <h2>Comprehensive care, precisely shaped around you.</h2>
      <div class="grid grid-3" style="margin-top:32px">
        {services.map(([title,desc,icon]) => (
          <article class="card service-card">
            <div class="icon">{icon}</div>
            <div><h3>{title}</h3><p class="muted">{desc}</p><a href="/treatments">Explore treatment →</a></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid grid-2" style="align-items:center">
      <div>
        <span class="eyebrow" style="color:#d7bf92">Digital Smile Design</span>
        <h2>See the vision before treatment begins.</h2>
        <p class="muted">Photography, intraoral scanning and facial analysis come together to plan tooth proportions, balance and the smile line before treatment.</p>
      </div>
      <div class="beforeafter">
        <div class="before">ANALYZE</div><div class="after">DESIGN</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2" style="align-items:center">
      <div class="card" style="min-height:420px;background:linear-gradient(145deg,#efe7da,#fff);display:grid;place-items:center">
        <div style="text-align:center"><span class="pill">3D Planning</span><h2 style="margin-top:18px">Technology amplifies clinical expertise.</h2></div>
      </div>
      <div>
        <span class="eyebrow">Why MOVA?</span>
        <h2>Clarity, precision and care without unnecessary treatment.</h2>
        <p class="lead">Instead of one formula for every patient, we consider oral anatomy, aesthetic expectations and long-term health as one connected plan.</p>
        <div class="grid" style="margin-top:24px">
          <div class="card"><h3>Transparent planning</h3><p class="muted">The process, alternatives and costs are explained before treatment begins.</p></div>
          <div class="card"><h3>Connected expertise</h3><p class="muted">Implant, aesthetic, orthodontic and endodontic care progress as one plan.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container cta">
      <div><span class="eyebrow" style="color:#d7bf92">Your First Step</span><h2>Let’s define the right path for your smile.</h2><p style="color:rgba(255,255,255,.72)">Share your goals and our patient coordinator will contact you.</p></div>
      <a class="btn btn-light" href="/contact">Request appointment</a>
    </div>
  </section>
</BaseLayout>
